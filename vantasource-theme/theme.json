{
  "name": "VANTASOURCE",
  "description": "Professional WordPress theme for global product sourcing, quality control, and international logistics business",
  "version": "1.3",
  "author": "VANTASOURCE Team",
  "authorUrl": "https://vantasource.com",
  "themeUrl": "https://vantasource.com",
  "documentationUrl": "https://vantasource.com/docs",
  "requires": {
    "wordpress": "5.8+",
    "php": "7.4+",
    "jquery": "3.5+"
  },
  "features": [
    "Responsive Design",
    "Bootstrap 5 Framework",
    "Custom Post Types",
    "AJAX Forms",
    "Smooth Animations",
    "Multilingual Support",
    "Mobile Optimized",
    "SEO Friendly",
    "Accessibility Ready"
  ],
  "colors": {
    "primary": "#667eea",
    "secondary": "#764ba2",
    "accent": "#3b82f6",
    "light": "#f8fafc",
    "dark": "#0f172a",
    "success": "#10b981",
    "warning": "#f59e0b",
    "danger": "#ef4444"
  },
  "dependencies": {
    "external": [
      "Bootstrap 5.3.0 (CDN)",
      "Bootstrap Icons 1.11.0 (CDN)",
      "Google Fonts: Inter (CDN)",
      "jQuery 3.6+ (WordPress)",
      "AOS - Animate On Scroll (CDN)"
    ]
  },
  "postTypes": [
    {
      "name": "service",
      "label": "Services",
      "supports": ["title", "editor", "thumbnail", "excerpt"],
      "hasArchive": true
    },
    {
      "name": "portfolio",
      "label": "Portfolio",
      "supports": ["title", "editor", "thumbnail", "excerpt"],
      "hasArchive": true
    },
    {
      "name": "testimonial",
      "label": "Testimonials",
      "supports": ["title", "editor", "thumbnail"],
      "public": false
    }
  ],
  "taxonomies": [
    {
      "name": "service_category",
      "postType": "service",
      "label": "Service Categories",
      "hierarchical": true
    },
    {
      "name": "industry",
      "postType": "portfolio",
      "label": "Industries",
      "hierarchical": true
    }
  ],
  "pageTemplates": {
    "front-page.php": "Front Page - Home",
    "page-about.php": "About Us",
    "page-contact.php": "Contact Us",
    "page-quote.php": "Request a Quote",
    "archive-service.php": "Services Archive",
    "archive-portfolio.php": "Portfolio Archive",
    "single-service.php": "Single Service",
    "single-portfolio.php": "Case Study Detail",
    "404.php": "Error 404"
  },
  "customFields": [
    {
      "key": "_client_name",
      "label": "Client Name",
      "type": "text"
    },
    {
      "key": "_project_date",
      "label": "Project Date",
      "type": "date"
    },
    {
      "key": "_project_result",
      "label": "Project Results",
      "type": "textarea"
    }
  ],
  "styleguide": {
    "headings": {
      "h1": "3.5rem (56px), font-weight: 800",
      "h2": "2.5rem (40px), font-weight: 800",
      "h3": "2rem (32px), font-weight: 700",
      "h4": "1.5rem (24px), font-weight: 700",
      "h5": "1.25rem (20px), font-weight: 600",
      "h6": "1rem (16px), font-weight: 600"
    },
    "body": "1rem (16px), font-weight: 400, line-height: 1.6"
  },
  "forms": {
    "contact": {
      "action": "vantasource_contact_form",
      "fields": ["name", "email", "phone", "company", "subject", "message"]
    },
    "rfq": {
      "action": "vantasource_rfq",
      "fields": ["name", "email", "phone", "company", "product_name", "category", "quantity", "timeline", "specifications", "budget_min", "budget_max", "origin", "incoterm", "notes"]
    }
  },
  "scripts": [
    {
      "id": "bootstrap-bundle",
      "src": "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js",
      "deps": ["jquery"],
      "version": "5.3.0"
    },
    {
      "id": "aos-js",
      "src": "https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js",
      "version": "2.3.4"
    },
    {
      "id": "vantasource-custom",
      "src": "/custom.js",
      "deps": ["jquery", "bootstrap-bundle", "aos-js"],
      "version": "1.0"
    }
  ],
  "styles": [
    {
      "id": "google-fonts",
      "src": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    },
    {
      "id": "bootstrap",
      "src": "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css",
      "version": "5.3.0"
    },
    {
      "id": "bootstrap-icons",
      "src": "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css",
      "version": "1.11.0"
    },
    {
      "id": "aos",
      "src": "https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css",
      "version": "2.3.4"
    },
    {
      "id": "vantasource-style",
      "src": "/style.css",
      "version": "1.3"
    }
  ],
  "menus": [
    {
      "location": "primary",
      "description": "Main Navigation Menu"
    },
    {
      "location": "footer",
      "description": "Footer Menu"
    }
  ],
  "changelog": {
    "1.3": [
      "Added comprehensive RFQ page template",
      "Enhanced form handling with AJAX",
      "Added timeline component",
      "Improved animations with AOS",
      "Enhanced color scheme and gradients",
      "Added 404 error page",
      "Added service and portfolio single templates",
      "Improved footer with comprehensive links"
    ],
    "1.2": [
      "Initial theme setup",
      "Bootstrap 5 integration",
      "Custom post types added",
      "Form handlers implemented"
    ]
  }
}
